# Environment Configuration for start-srv
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Server Configuration
HOST=127.0.0.1
PORT=8080

# Session Configuration
# Must be at least 64 bytes for cookie session security.
# Generate with: openssl rand -base64 64
SESSION_SECRET=CHANGE_THIS_IN_PRODUCTION_TO_A_SECURE_64_BYTE_MINIMUM_SECRET_KEY_HERE!!

# Cookie Security
# Set to "true" in production (requires HTTPS).
# Default: false (for local development over HTTP)
COOKIE_SECURE=false

# CORS Configuration
# Comma-separated list of allowed origins.
# Leave empty only for local development (allows all origins with a warning).
# Production example: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Supabase Configuration
# Find these in your Supabase project: Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
